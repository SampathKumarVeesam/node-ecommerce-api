# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Local Development: mongodb://localhost:27017/ecommerce-db
# Cloud MongoDB Atlas: mongodb+srv://<username>:<password>@<cluster-url>/ecommerce-db?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/ecommerce-db

# Authentication
JWT_SECRET=your_jwt_secret_key_should_be_long_and_random
JWT_EXPIRE=30d
